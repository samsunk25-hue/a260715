{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "firestore.rules",

      "**/.*",
      ".git/**",
      ".claude/**",

      "**/node_modules/**",
      "**/*.ps1",
      "**/*.docx",
      "**/*.md"
    ],
    "headers": [
      {
        "source": "**/*.@(js|css|html)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache"
          }
        ]
      }
    ]
  }
}
