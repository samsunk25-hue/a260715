// =====================================================================
//  Firestore 보안 규칙 — 스터디 드래곤
// ---------------------------------------------------------------------
//  ★ 이 파일은 콘솔에 실제로 게시된 규칙의 사본입니다 (2026-07-16 기준).
//
//  이 파일을 고쳐도 저절로 반영되지 않습니다.
//  반드시 아래 주소에 붙여넣고 [게시] 버튼까지 눌러야 적용됩니다.
//    console.firebase.google.com/project/study-dragon/firestore/rules
//
//  검증 완료 (실제 요청을 던져 확인함)
//    ✅ 정상 응원 작성  → 허용
//    🛡️ 기존 응원 수정  → 차단
//    🛡️ 기존 응원 삭제  → 차단
//    🛡️ 200자 초과      → 차단
//    🛡️ 빈 메시지       → 차단
// =====================================================================

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 반 — 코드로 존재를 확인하고, 학생이 오탈자를 알아채게 합니다.
    //   개인정보 없음: 반 이름과 만든 시각뿐입니다.
    match /classes/{code} {
      allow read: if true;
      allow create: if request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() < 30
                    && request.resource.data.keys().hasOnly(['name', 'createdAt']);
      allow update, delete: if false;   // 한 번 만든 반은 못 바꾸고 못 지움
    }

    // 응원 메시지
    //   cm = "반코드|년월". 반별 조회 열쇠입니다. 문자열이어야 합니다.
    match /cheers/{id} {
      allow read: if true;

      allow create: if request.resource.data.cm is string
                    && request.resource.data.message is string
                    && request.resource.data.message.size() > 0
                    && request.resource.data.message.size() < 200;

      // ★ 수정·삭제 전면 금지
      //   교사와 학부모가 같은 날에 각각 응원을 씁니다.
      //   이 한 줄이 앞사람 메시지가 덮어써지거나 지워지는 것을
      //   데이터베이스 차원에서 불가능하게 만듭니다.
      allow update, delete: if false;
    }

    // 선생님 지정 과제 — 교사가 편집
    //   list = 과제 3개. 정확히 3개일 때만 허용(하트 칸 수 계산 보호).
    //   cm = "반코드|년월" 반별 조회 열쇠.
    match /tasks/{id} {
      allow read: if true;

      allow write: if request.resource.data.cm is string
                   && request.resource.data.list is list
                   && request.resource.data.list.size() == 3
                   && request.resource.data.list[0] is string
                   && request.resource.data.list[1] is string
                   && request.resource.data.list[2] is string
                   && request.resource.data.list[0].size() > 0
                   && request.resource.data.list[0].size() < 40
                   && request.resource.data.list[1].size() > 0
                   && request.resource.data.list[1].size() < 40
                   && request.resource.data.list[2].size() > 0
                   && request.resource.data.list[2].size() < 40
                   && request.resource.data.date is string
                   && request.resource.data.keys().hasOnly(['cm', 'date', 'list', 'updatedAt']);

      allow delete: if false;
    }

    // 익명 진도 통계 — 교사가 반 분위기를 보기 위한 것
    //
    // ★ 여기에 개인정보가 들어가면 안 됩니다 ★
    //   저장되는 건 { cd, date, count, updatedAt } 뿐입니다.
    //   이름도 별명도 없고, 문서 ID의 기기 구분자는 앱이 만든 난수라
    //   사람과 연결되지 않습니다. hasOnly로 필드를 잠가
    //   나중에 실수로 이름 같은 걸 끼워 넣는 것도 막습니다.
    //   cd = "반코드|날짜" 반별 조회 열쇠.
    match /stats/{id} {
      allow read: if true;

      allow write: if request.resource.data.cd is string
                   && request.resource.data.count is int
                   && request.resource.data.count >= 0
                   && request.resource.data.count <= 4
                   && request.resource.data.date is string
                   && request.resource.data.date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
                   && request.resource.data.keys().hasOnly(['cd', 'date', 'count', 'updatedAt']);

      allow delete: if false;
    }

    // ※ 위 경로에 안 걸리는 다른 컬렉션은 Firestore 기본값(거부)으로 막힙니다.
  }
}

// ---------------------------------------------------------------------
//  나중에 더 단단히 하고 싶다면 (지금은 없어도 동작에 지장 없음)
//
//  allow create 조건에 아래 두 줄을 추가하면 date 필드까지 검사합니다.
//    && request.resource.data.date is string
//    && request.resource.data.date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
//
//  지금도 안전한 이유: 날짜가 이상한 문서가 들어와도
//  firebase.js의 fetchCheersForMonth가 날짜 범위로 걸러내고,
//  date나 message가 없는 문서는 건너뜁니다.
// ---------------------------------------------------------------------

// ---------------------------------------------------------------------
//  알려진 한계
//
//  로그인이 없어서 주소를 아는 사람은 누구나 응원을 쓸 수 있습니다.
//  교실 시연·과제 제출 수준에서는 괜찮지만, 실제로 여러 학교에
//  배포한다면 Firebase Authentication이 필요합니다.
//
//  부적절한 메시지는 위 규칙상 앱에서 지울 수 없으므로
//  Firebase 콘솔의 Firestore Database 화면에서 직접 삭제해야 합니다.
//  (콘솔은 이 규칙의 적용을 받지 않습니다.)
// ---------------------------------------------------------------------
