// =====================================================================
//  Firestore 보안 규칙 — 스터디 드래곤
// ---------------------------------------------------------------------
//  ★ 이 파일은 콘솔에 실제로 게시된 규칙의 사본입니다 (2026-07-16 기준).
//
//  이 파일을 고쳐도 저절로 반영되지 않습니다.
//  반드시 아래 주소에 붙여넣고 [게시] 버튼까지 눌러야 적용됩니다.
//    console.firebase.google.com/project/study-dragon/firestore/rules
//
//  검증 완료 (실제 요청을 던져 확인함)
//    ✅ 정상 응원 작성  → 허용
//    🛡️ 기존 응원 수정  → 차단
//    🛡️ 기존 응원 삭제  → 차단
//    🛡️ 200자 초과      → 차단
//    🛡️ 빈 메시지       → 차단
// =====================================================================

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 응원 메시지 — 이 앱이 쓰는 유일한 컬렉션
    match /cheers/{id} {

      // 누구나 읽기 (로그인이 없는 앱이라 모든 학생이 봐야 함)
      allow read: if true;

      // 만들기: 메시지는 1~199자 문자열이어야 함
      allow create: if request.resource.data.message is string
                    && request.resource.data.message.size() > 0
                    && request.resource.data.message.size() < 200;

      // ★ 수정·삭제 전면 금지
      //   교사와 학부모가 같은 날에 각각 응원을 씁니다.
      //   이 한 줄이 앞사람 메시지가 덮어써지거나 지워지는 것을
      //   데이터베이스 차원에서 불가능하게 만듭니다.
      allow update, delete: if false;
    }

    // ※ cheers 외의 경로를 따로 막지 않은 이유
    //   Firestore는 어떤 규칙에도 걸리지 않으면 "기본 거부"입니다.
    //   따로 차단 블록을 쓰지 않아도 다른 컬렉션은 이미 막혀 있습니다.
  }
}

// ---------------------------------------------------------------------
//  나중에 더 단단히 하고 싶다면 (지금은 없어도 동작에 지장 없음)
//
//  allow create 조건에 아래 두 줄을 추가하면 date 필드까지 검사합니다.
//    && request.resource.data.date is string
//    && request.resource.data.date.matches('^[0-9]{4}-[0-9]{2}-[0-9]{2}$')
//
//  지금도 안전한 이유: 날짜가 이상한 문서가 들어와도
//  firebase.js의 fetchCheersForMonth가 날짜 범위로 걸러내고,
//  date나 message가 없는 문서는 건너뜁니다.
// ---------------------------------------------------------------------

// ---------------------------------------------------------------------
//  알려진 한계
//
//  로그인이 없어서 주소를 아는 사람은 누구나 응원을 쓸 수 있습니다.
//  교실 시연·과제 제출 수준에서는 괜찮지만, 실제로 여러 학교에
//  배포한다면 Firebase Authentication이 필요합니다.
//
//  부적절한 메시지는 위 규칙상 앱에서 지울 수 없으므로
//  Firebase 콘솔의 Firestore Database 화면에서 직접 삭제해야 합니다.
//  (콘솔은 이 규칙의 적용을 받지 않습니다.)
// ---------------------------------------------------------------------
